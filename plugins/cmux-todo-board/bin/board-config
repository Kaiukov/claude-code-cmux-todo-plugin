#!/usr/bin/env bash
set -euo pipefail

DEFAULT_LANG="EN"
DEFAULT_PROFILES_JSON='{"backend":{"role":"backend","provider":"opencode-go","model":"deepseek-v4-pro","thinking":"high","tools":"read,bash,edit,write,grep,find,ls"},"backend-fast":{"role":"backend","provider":"opencode","model":"deepseek-v4-flash-free","thinking":"low","tools":"read,bash,edit,write,grep,find,ls"},"repo-scout":{"role":"review","provider":"opencode","model":"nemotron-3-ultra-free","thinking":"medium","tools":"read,bash,grep,find,ls"},"docs":{"role":"docs","provider":"opencode","model":"mimo-v2.5-free","thinking":"low","tools":"read,bash,edit,write,grep,find,ls"},"test":{"role":"backend","provider":"openai-codex","model":"gpt-5.4-mini","thinking":"medium","tools":"read,bash,edit,write,grep,find,ls"},"tiny-patch":{"role":"backend","provider":"openai-codex","model":"gpt-5.4-mini","thinking":"low","tools":"read,bash,edit,write,grep,find,ls"},"review":{"role":"review","provider":"opencode-go","model":"deepseek-v4-pro","thinking":"high","tools":"read,bash,grep,find,ls"},"frontend":{"role":"frontend","provider":"anthropic","model":"claude-sonnet-4-6","model_status":"TBC","gate":"user-permission","thinking":"medium","tools":"read,bash,edit,write,grep,find,ls"},"frontend-top":{"role":"frontend-top","provider":"anthropic","model":"claude-opus-4-8","model_status":"TBC","gate":"user-permission","thinking":"high","tools":"read,bash,edit,write,grep,find,ls"}}'
VALID_PROFILES=(backend backend-fast repo-scout docs test tiny-patch review frontend frontend-top)
CONFIG_FILE=".tasks/config.json"

usage() {
  cat <<EOF
Usage: board-config --get
       board-config --set-language <code>
       board-config --get-profile <name> [--provider] [--model] [--thinking] [--tools] [--role] [--json]
       board-config --help|-h

Manage board runtime configuration stored in ${CONFIG_FILE}.

Commands:
  --get                 Print the current language. Defaults to ${DEFAULT_LANG}
                        if no config file or language key is set.
  --set-language <code> Write/update the language in ${CONFIG_FILE},
                        preserving any other keys. Code is normalized
                        (uppercased, trimmed). Rejects empty/whitespace.
  --get-profile <name>  Resolve a Pi role profile (backend|backend-fast|
                        repo-scout|docs|test|tiny-patch|review|frontend|
                        frontend-top). Reads overrides from .profiles.<name> in
                        ${CONFIG_FILE}, falls back to built-in defaults.
    --provider          Print the provider field only.
    --model             Print the model field only (default if no selector).
    --thinking          Print the thinking field only.
    --tools             Print the tools field only.
    --role              Print the role field only.
    --json              Print full resolution as JSON:
                        {provider, model, thinking, tools, role}.
  --help, -h            Show this help message.
EOF
  exit 0
}

# --- Pure functions (no file I/O) ---

# normalize_lang <raw> — uppercase, trim, reject empty/whitespace.
# Prints the normalized code on stdout. Returns non-zero on invalid input.
normalize_lang() {
  local raw="$1"

  local trimmed
  trimmed="$(echo "$raw" | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')"

  if [[ -z "$trimmed" ]]; then
    echo "board-config: language code must not be empty or whitespace" >&2
    return 1
  fi

  echo "$trimmed" | tr '[:lower:]' '[:upper:]'
}

# resolve_language <json> — print language from config JSON or EN default.
# <json> is the raw content of .tasks/config.json (may be empty/missing).
resolve_language() {
  local json="$1"

  if [[ -z "$json" ]]; then
    echo "$DEFAULT_LANG"
    return
  fi

  local lang
  lang="$(echo "$json" | jq -r '.language // empty' 2>/dev/null)"

  if [[ -z "$lang" ]]; then
    echo "$DEFAULT_LANG"
  else
    echo "$lang"
  fi
}

# --- Profile resolver (mirrors resolve_model_full) ---

# resolve_profile_full <name> <config_json> — resolve profile to {provider, model, thinking, tools}.
# Precedence: .profiles.<name> in config overrides built-in default (deep-merge per field).
# Unknown profile → non-zero exit + stderr message listing valid names.
resolve_profile_full() {
  local name="$1"
  local config_json="$2"

  local found="" p
  for p in "${VALID_PROFILES[@]}"; do
    [[ "$name" == "$p" ]] && found=1 && break
  done
  if [[ -z "$found" ]]; then
    echo "board-config: unknown profile '${name}'. Valid: ${VALID_PROFILES[*]}" >&2
    return 1
  fi

  # Start with the built-in default
  local provider model thinking tools model_status role
  provider="$(echo "$DEFAULT_PROFILES_JSON" | jq -r --arg n "$name" '.[$n].provider')"
  model="$(echo "$DEFAULT_PROFILES_JSON" | jq -r --arg n "$name" '.[$n].model')"
  thinking="$(echo "$DEFAULT_PROFILES_JSON" | jq -r --arg n "$name" '.[$n].thinking')"
  tools="$(echo "$DEFAULT_PROFILES_JSON" | jq -r --arg n "$name" '.[$n].tools')"
  model_status="$(echo "$DEFAULT_PROFILES_JSON" | jq -r --arg n "$name" '.[$n].model_status // empty')"
  role="$(echo "$DEFAULT_PROFILES_JSON" | jq -r --arg n "$name" '.[$n].role // empty')"

  # Override from config if present (deep-merge per field)
  if [[ -n "$config_json" ]]; then
    local override
    override="$(echo "$config_json" | jq -r --arg n "$name" '.profiles[$n] // empty' 2>/dev/null)"
    if [[ -n "$override" ]]; then
      local ov_provider ov_model ov_thinking ov_tools ov_model_status ov_role
      ov_provider="$(echo "$override" | jq -r '.provider // empty')"
      ov_model="$(echo "$override" | jq -r '.model // empty')"
      ov_thinking="$(echo "$override" | jq -r '.thinking // empty')"
      ov_tools="$(echo "$override" | jq -r '.tools // empty')"
      ov_model_status="$(echo "$override" | jq -r '.model_status // empty')"
      ov_role="$(echo "$override" | jq -r '.role // empty')"
      [[ -n "$ov_provider" ]] && provider="$ov_provider"
      [[ -n "$ov_model" ]] && model="$ov_model"
      [[ -n "$ov_thinking" ]] && thinking="$ov_thinking"
      [[ -n "$ov_tools" ]] && tools="$ov_tools"
      [[ -n "$ov_model_status" ]] && model_status="$ov_model_status"
      [[ -n "$ov_role" ]] && role="$ov_role"
    fi
  fi

  # Default role to profile name for backward compatibility
  [[ -z "$role" ]] && role="$name"

  jq -n --arg provider "$provider" --arg model "$model" --arg thinking "$thinking" --arg tools "$tools" --arg model_status "$model_status" --arg role "$role" \
    '{provider: $provider, model: $model, thinking: $thinking, tools: $tools, role: $role} + (if $model_status != "" then {model_status: $model_status} else {} end)'
}

# resolve_profile <name> <json> — print model id for profile. Backward-compatible wrapper.
resolve_profile() {
  local result
  if ! result="$(resolve_profile_full "$1" "$2")"; then
    return 1
  fi
  echo "$result" | jq -r '.model'
}

# --- Main ---

if [[ $# -gt 0 && ( "$1" == "--help" || "$1" == "-h" ) ]]; then
  usage
fi

if [[ $# -eq 1 && "$1" == "--get" ]]; then
  if [[ -f "$CONFIG_FILE" ]]; then
    json="$(cat "$CONFIG_FILE")"
  else
    json=""
  fi
  resolve_language "$json"
  exit 0
fi

if [[ $# -ge 2 && "$1" == "--set-language" ]]; then
  if ! code="$(normalize_lang "$2")"; then
    exit 1
  fi

  mkdir -p "$(dirname "$CONFIG_FILE")"

  existing="{}"
  if [[ -f "$CONFIG_FILE" ]]; then
    existing="$(cat "$CONFIG_FILE")"
  fi

  echo "$existing" | jq --arg lang "$code" '. + {language: $lang}' > "${CONFIG_FILE}.tmp"
  mv "${CONFIG_FILE}.tmp" "$CONFIG_FILE"
  echo "$code"
  exit 0
fi


if [[ $# -ge 2 && "$1" == "--get-profile" ]]; then
  name="$2"
  shift 2

  if [[ -f "$CONFIG_FILE" ]]; then
    json="$(cat "$CONFIG_FILE")"
  else
    json=""
  fi

  show_provider=""
  show_model=""
  show_thinking=""
  show_tools=""
  show_role=""
  show_json=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --provider) show_provider=1 ;;
      --model)    show_model=1 ;;
      --thinking) show_thinking=1 ;;
      --tools)    show_tools=1 ;;
      --role)     show_role=1 ;;
      --json)     show_json=1 ;;
      *) echo "board-config: unknown flag '$1' for --get-profile" >&2; exit 1 ;;
    esac
    shift
  done

  if ! result="$(resolve_profile_full "$name" "$json")"; then
    exit 1
  fi

  if [[ -n "$show_json" ]]; then
    echo "$result" | jq '.'
  elif [[ -n "$show_provider" ]]; then
    echo "$result" | jq -r '.provider'
  elif [[ -n "$show_model" ]]; then
    echo "$result" | jq -r '.model'
  elif [[ -n "$show_thinking" ]]; then
    echo "$result" | jq -r '.thinking'
  elif [[ -n "$show_tools" ]]; then
    echo "$result" | jq -r '.tools'
  elif [[ -n "$show_role" ]]; then
    echo "$result" | jq -r '.role'
  else
    echo "$result" | jq -r '.model'
  fi
  exit 0
fi

echo "board-config: missing or unknown command. Use --help." >&2
exit 1
