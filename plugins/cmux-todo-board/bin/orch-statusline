#!/usr/bin/env bash
# orch-statusline — Claude Code statusLine: list of running orchestrator agents.
# Reads stdin (Claude Code session JSON, used only for cwd), then derives live
# agents from tmux `orch-*` sessions cross-referenced with their run records:
#   .tasks/orchestrator/runs/<issue>-<role>-<timestamp>.json
# Output (one line):  🤖 orch-153-backend · openai-codex/gpt-5.4-mini · reconcile V1 seams [running]
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PLUGIN_ROOT="${CLAUDE_PLUGIN_ROOT:-$(cd "$SCRIPT_DIR/.." && pwd)}"

mark_reported() {
  local file="$1" tmp
  [[ -f "$file" ]] || return 0
  tmp="${file}.tmp"
  jq --arg ts "$(date -u +%Y-%m-%dT%H:%M:%SZ)" '
    .reported_at = $ts
  ' "$file" > "$tmp"
  mv "$tmp" "$file"
}

status_icon() {
  case "$1" in
    done) printf '✅' ;;
    killed_timeout|killed_stalled) printf '🟡' ;;
    crashed) printf '🔴' ;;
    *) printf '🤖' ;;
  esac
}

resolve_runs_dir() {
  local cwd="$1" candidate d
  if [[ -n "${ORCH_REPO_ROOT:-}" ]]; then
    candidate="$ORCH_REPO_ROOT/.tasks/orchestrator/runs"
    if [[ -d "$candidate" ]]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  else
    candidate="$(git -C "$cwd" rev-parse --show-toplevel 2>/dev/null || true)"
    if [[ -n "$candidate" ]]; then
      candidate="$candidate/.tasks/orchestrator/runs"
      if [[ -d "$candidate" ]]; then
        printf '%s\n' "$candidate"
        return 0
      fi
    fi
  fi

  # Canonical location: plugin root next to orch-tmux-spawn/orch-tmux-runner.
  if [[ -d "$PLUGIN_ROOT/.tasks/orchestrator/runs" ]]; then
    printf '%s\n' "$PLUGIN_ROOT/.tasks/orchestrator/runs"
    return 0
  fi

  # Legacy fallback: walk up from cwd to support the pre-relocation layout.
  d="$cwd"
  for _ in 1 2 3 4 5 6; do
    if [[ -d "$d/.tasks/orchestrator/runs" ]]; then
      printf '%s\n' "$d/.tasks/orchestrator/runs"
      return 0
    fi
    d="$(dirname "$d")"
    [[ "$d" == "/" ]] && break
  done
  return 0
}

input="$(cat 2>/dev/null || true)"
cwd=""
if command -v jq >/dev/null 2>&1 && [[ -n "$input" ]]; then
  cwd="$(jq -r '.workspace.current_dir // .cwd // empty' <<<"$input" 2>/dev/null || true)"
fi
[[ -n "$cwd" ]] || cwd="$PWD"

runs="$(resolve_runs_dir "$cwd")"

# Live agent sessions (tmux is transport-liveness only).
sessions=()
if command -v tmux >/dev/null 2>&1; then
  while IFS= read -r s; do [[ -n "$s" ]] && sessions+=("$s"); done \
    < <(tmux list-sessions -F '#{session_name}' 2>/dev/null | grep '^orch-' || true)
fi

if (( ${#sessions[@]} == 0 )); then
  if [[ -n "$runs" && -d "$runs" ]] && command -v jq >/dev/null 2>&1; then
    seen_keys=$'\n'
    finished_parts=()
    finished_files=()
    while IFS= read -r f; do
      [[ -n "$f" ]] || continue
      base="$(basename "$f" .json)"
      key="${base%-*}"
      [[ "$seen_keys" == *$'\n'"$key"$'\n'* ]] && continue
      seen_keys+="${key}"$'\n'

      state="$(jq -r '.status // "running"' "$f" 2>/dev/null || echo running)"
      reported_at="$(jq -r '.reported_at // empty' "$f" 2>/dev/null || true)"
      [[ -n "$reported_at" ]] && continue
      case "$state" in
        done|killed_timeout|killed_stalled|crashed) ;;
        *) continue ;;
      esac

      agent="$(jq -r '.agent // .tmux_session // .session // empty' "$f" 2>/dev/null || true)"
      [[ -n "$agent" ]] || agent="orch-$key"
      model="$(jq -r '.model // ((.profile.provider // "?")+"/"+(.profile.model // "?"))' "$f" 2>/dev/null || echo "?")"
      task="$(jq -r '.task // empty' "$f" 2>/dev/null || true)"
      icon="$(status_icon "$state")"
      line="$agent · $model"
      [[ -n "$task" ]] && line="$line · $task"
      line="$line [$state]"
      finished_parts+=("$icon $line")
      finished_files+=("$f")
    done < <(ls -t "$runs"/*.json 2>/dev/null || true)

    if (( ${#finished_parts[@]} > 0 )); then
      out="${finished_parts[0]}"
      for ((i=1; i<${#finished_parts[@]}; i++)); do out="$out  │  ${finished_parts[$i]}"; done
      for f in "${finished_files[@]}"; do
        mark_reported "$f"
      done
      printf '%s\n' "$out"
      exit 0
    fi
  fi
  printf '🟢 orchestrator idle — no agents running\n'
  exit 0
fi

parts=()
for s in "${sessions[@]}"; do
  key="${s#orch-}"                       # <issue>-<role>
  model="?"; task=""; state="running"
  record_file=""
  if [[ -n "$runs" ]]; then
    record_file="$(ls -t "$runs/$key-"*.json 2>/dev/null | head -1 || true)"
  fi
  if [[ -n "$record_file" && -s "$record_file" ]]; then
    model="$(jq -r '.model // ((.profile.provider // "?")+"/"+(.profile.model // "?"))' "$record_file" 2>/dev/null || echo "?")"
    task="$(jq -r '.task // empty' "$record_file" 2>/dev/null || true)"
    state="$(jq -r '.status // "running"' "$record_file" 2>/dev/null || echo running)"
  fi
  if [[ "$model" == "?" ]] && command -v ps >/dev/null 2>&1; then
    runner_cmd="$(ps -ef 2>/dev/null | grep "orch-tmux-runner.sh" | grep -- "--run-file .*${key}-" | grep -v grep | head -1 || true)"
    if [[ -n "$runner_cmd" ]]; then
      if [[ "$runner_cmd" =~ --model[[:space:]]([^[:space:]]+) ]]; then
        model="${BASH_REMATCH[1]}"
      elif [[ "$runner_cmd" =~ --profile[[:space:]]([^[:space:]]+) ]]; then
        model="profile:${BASH_REMATCH[1]}"
      fi
    fi
  fi
  line="$s · $model"
  [[ -n "$task" ]] && line="$line · $task"
  line="$line [$state]"
  parts+=("🤖 $line")
done

# One line; join multiple agents with a separator.
out="${parts[0]}"
for ((i=1; i<${#parts[@]}; i++)); do out="$out  │  ${parts[$i]}"; done
printf '%s\n' "$out"
