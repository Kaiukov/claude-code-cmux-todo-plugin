#!/usr/bin/env python3
"""board-render: Read .tasks/issues.json, write .tasks/board.json and TODO.md."""
import json
import sys
from pathlib import Path

# Canonical status order
STATUS_ORDER = [
    "inbox",
    "ready",
    "in-progress",
    "needs-review",
    "blocked",
    "needs-info",
    "done",
]

def derive_status(labels: list[dict] | list[str]) -> str:
    """Derive canonical status from a list of labels (GitHub API format).

    Walks STATUS_ORDER in reverse so the most-progressed status wins
    when an issue has multiple status labels (e.g. both inbox and ready).
    Legacy 'completed' label maps to 'done'.
    """
    label_names = set()
    for label in labels:
        if isinstance(label, dict):
            name = label.get("name", "").lower()
        else:
            name = str(label).lower()
        label_names.add(name)

    # Reverse walk: most-progressed status wins (last match in canonical order)
    for status in reversed(STATUS_ORDER):
        if status in label_names:
            return status

    # Check legacy completed
    if "completed" in label_names:
        return "done"

    return "inbox"  # default fallback


def render(input_path: Path, board_path: Path, todo_path: Path) -> None:
    """Read issues.json, write board.json and TODO.md."""

    with open(input_path) as f:
        issues = json.load(f)

    if not isinstance(issues, list):
        print(f"board-render: expected JSON array, got {type(issues).__name__}",
              file=sys.stderr)
        sys.exit(1)

    # Build board list
    board = []
    for issue in issues:
        number = issue.get("number", 0)
        title = issue.get("title", "untitled")
        labels = issue.get("labels") or []
        status = derive_status(labels)
        url = issue.get("url", "")
        assignees_raw = issue.get("assignees") or []
        assignee_names = []
        for a in assignees_raw:
            if isinstance(a, dict):
                assignee_names.append(a.get("login", ""))
            else:
                assignee_names.append(str(a))

        board.append({
            "number": number,
            "title": title,
            "status": status,
            "labels": [lbl.get("name", str(lbl)) if isinstance(lbl, dict) else str(lbl)
                       for lbl in labels],
            "url": url,
            "assignees": assignee_names,
        })

    # Deterministic sort: by canonical status order, then by issue number
    status_rank = {s: i for i, s in enumerate(STATUS_ORDER)}
    board.sort(key=lambda t: (status_rank.get(t["status"], 99), t["number"]))

    # Ensure .tasks directory exists
    board_path.parent.mkdir(parents=True, exist_ok=True)

    # Write board.json
    with open(board_path, "w") as f:
        json.dump(board, f, indent=2)
        f.write("\n")

    # Group by status for TODO.md
    groups: dict[str, list[dict]] = {s: [] for s in STATUS_ORDER}
    for task in board:
        groups[task["status"]].append(task)

    # Build TODO.md lines
    lines = []
    lines.append("<!-- generated by board-render -- do not edit -->")
    lines.append("")
    lines.append("# Task Board")
    lines.append("")

    for status in STATUS_ORDER:
        tasks = groups.get(status, [])
        if not tasks:
            continue
        lines.append(f"## {status}")
        lines.append("")
        for t in tasks:
            assignee_str = ""
            if t["assignees"]:
                assignee_str = " (@" + ", @".join(t["assignees"]) + ")"
            lines.append(f"- [ ] [#{t['number']}] {t['title']}{assignee_str}")
        lines.append("")

    with open(todo_path, "w") as f:
        f.write("\n".join(lines) + "\n")


def main() -> None:
    root = Path.cwd()
    input_file = root / ".tasks" / "issues.json"
    board_file = root / ".tasks" / "board.json"
    todo_file = root / "TODO.md"

    if not input_file.exists():
        print(f"board-render: {input_file} not found. Run board-pull first.",
              file=sys.stderr)
        sys.exit(1)

    render(input_file, board_file, todo_file)

    # Print summary to stderr
    with open(board_file) as f:
        board = json.load(f)
    total = len(board)
    ready = sum(1 for t in board if t["status"] == "ready")
    blocked = sum(1 for t in board if t["status"] == "blocked")
    in_progress = sum(1 for t in board if t["status"] == "in-progress")
    print(
        f"board-render: {total} tasks → .tasks/board.json + TODO.md "
        f"(ready={ready}, in-progress={in_progress}, blocked={blocked})",
        file=sys.stderr)


if __name__ == "__main__":
    main()
