#!/usr/bin/env bash
set -euo pipefail

DATA_FILE="${LIMIT_DATA_FILE:-.tasks/limit-monitor.json}"
WARN_AT="${LIMIT_WARN_AT:-80}"
CRIT_AT="${LIMIT_CRIT_AT:-95}"
SURFACE=""

usage() {
  cat <<'EOF'
Usage: limit-monitor [--surface <ref>]

Read Claude Code status-line JSON from stdin. Extract rate_limits.seven_day.used_percentage
and rate_limits.seven_day.resets_at. Persist to .tasks/limit-monitor.json and alert at thresholds.

Environment:
  LIMIT_WARN_AT       Warning threshold percentage (default 80)
  LIMIT_CRIT_AT       Critical threshold percentage (default 95)
  LIMIT_DATA_FILE     Path to state file (default .tasks/limit-monitor.json)
EOF
  exit 0
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --surface) SURFACE="$2"; shift 2 ;;
    --help|-h) usage ;;
    *) echo "limit-monitor: unknown flag: $1" >&2; usage ;;
  esac
done

INPUT="$(cat)"

USED=$(echo "$INPUT" | jq -r '.rate_limits.seven_day.used_percentage // empty' 2>/dev/null || true)
RESETS_AT=$(echo "$INPUT" | jq -r '.rate_limits.seven_day.resets_at // empty' 2>/dev/null || true)

if [[ -z "$USED" || -z "$RESETS_AT" ]]; then
  echo "limit-monitor: rate_limits.seven_day not available (likely API-key auth) — skipping" >&2
  exit 0
fi

mkdir -p "$(dirname "$DATA_FILE")"

STORED_RESETS="0"
ALERTED_LIST=""

if [[ -f "$DATA_FILE" ]]; then
  STORED_RESETS=$(jq -r '.seven_day.resets_at // 0' "$DATA_FILE" 2>/dev/null || echo "0")
  ALERTED_LIST=$(jq -r '.seven_day.alerted_at_thresholds // [] | join(",")' "$DATA_FILE" 2>/dev/null || echo "")
fi

if [[ "$STORED_RESETS" != "$RESETS_AT" ]]; then
  ALERTED_LIST=""
fi

already_alerted() {
  local t="$1"
  [[ -n "$ALERTED_LIST" ]] || return 1
  local IFS=','
  local a
  for a in $ALERTED_LIST; do
    if [[ "$a" == "$t" ]]; then return 0; fi
  done
  return 1
}

add_alerted() {
  local t="$1"
  if [[ -n "$ALERTED_LIST" ]]; then
    ALERTED_LIST="${ALERTED_LIST},${t}"
  else
    ALERTED_LIST="$t"
  fi
}

NOW_ISO="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"

if awk "BEGIN {exit !($USED >= $CRIT_AT)}"; then
  if ! already_alerted "$CRIT_AT"; then
    echo "CRIT: weekly limit at ${USED}%" >&2
    if [[ -n "$SURFACE" ]] && command -v cmux &>/dev/null; then
      RESETS_HUMAN=$(date -r "$RESETS_AT" -u +"%Y-%m-%dT%H:%M:%SZ" 2>/dev/null || echo "epoch=$RESETS_AT")
      cmux notify --title "Limit Alert" --body "CRIT: weekly limit at ${USED}%. Resets at ${RESETS_HUMAN}" --surface "$SURFACE" 2>/dev/null || true
    fi
    add_alerted "$CRIT_AT"
  fi
fi

if awk "BEGIN {exit !($USED >= $WARN_AT)}"; then
  if ! already_alerted "$WARN_AT"; then
    echo "WARN: weekly limit at ${USED}%"
    add_alerted "$WARN_AT"
  fi
fi

ALERTED_JSON="[]"
if [[ -n "$ALERTED_LIST" ]]; then
  ALERTED_JSON="[${ALERTED_LIST}]"
fi

jq -n \
  --argjson schema_version 1 \
  --arg last_check "$NOW_ISO" \
  --argjson used_percentage "$USED" \
  --argjson resets_at "$RESETS_AT" \
  --argjson alerted "$ALERTED_JSON" \
  '{
    schema_version: $schema_version,
    last_check: $last_check,
    seven_day: {
      used_percentage: $used_percentage,
      resets_at: $resets_at,
      alerted_at_thresholds: $alerted
    }
  }' > "$DATA_FILE"

exit 0
