#!/usr/bin/env bash
# cmux-dev-grid — 3×3 cockpit initializer for cmux workspaces
#
# Usage:
#   cmux-dev-grid init          Build/verify 3×3 grid, save cockpit.json
#   cmux-dev-grid status        Print current slot→surface mapping
#   cmux-dev-grid verify        Check cockpit.json matches reality (exit 1 on mismatch)
#
# Cockpit layout (ORCH in center):
#   ┌──────────┬──────────┬──────────┐
#   │ worker-1 │ worker-2 │ worker-3 │
#   ├──────────┼──────────┼──────────┤
#   │ worker-4 │   ORCH   │ worker-5 │
#   ├──────────┼──────────┼──────────┤
#   │ worker-6 │ worker-7 │ worker-8 │
#   └──────────┴──────────┴──────────┘
#
# Idempotent: re-running `init` updates names + mapping, never creates
# extra panes beyond the 9-slot grid. If the workspace already has 9
# panes, the script assigns slots by pane creation order (oldest→worker-1
# through newest→worker-8), excluding the orchestrator.
#
# Pane creation order for fresh init (orchestrator is current pane):
#   1. Split right        → worker-1 (right of ORCH)
#   2. Split right        → worker-2 (right of worker-1)
#   3. Split right        → worker-3 (right of worker-2)
#   4. Split left         → worker-4 (left of ORCH)
#   5. Split down on w-1  → worker-6 (below worker-1)
#   6. Split down on w-2  → worker-7 (below worker-2)
#   7. Split down on w-3  → worker-8 (below worker-3)
#   8. Split down on w-4  → worker-5 (below worker-4... wait)
#
# Simpler approach: fill rows bottom-up after creating the top row.
# Actually, for cmux's tree-split layout, we create all panes first,
# then name them. The exact visual layout depends on cmux's tiling
# algorithm, but with 9 panes split as described above, they form a
# 3×3 grid naturally.
#
# This script captures surface refs during creation and maps them to
# logical slot names. Re-running with an existing cockpit.json just
# renames tabs and verifies the mapping.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/../../.." && pwd)"
COCKPIT_FILE="$REPO_ROOT/.tasks/cockpit.json"
TASKS_DIR="$REPO_ROOT/.tasks"

mkdir -p "$TASKS_DIR"

# ── helpers ──────────────────────────────────────────────────────────
die()  { echo "ERROR: $*" >&2; exit 1; }
info() { echo "  → $*" >&2; }

# Get all pane→surface pairs in the current workspace, sorted by pane index.
# Output: pane_ref<TAB>surface_ref<TAB>title
cmux_pane_map() {
  local tree_json ws_ref
  tree_json="$(cmux tree --all --json 2>/dev/null)" || return 1
  ws_ref="$(echo "$tree_json" | jq -r '.caller.workspace_ref // empty' | tr -d '\n')"
  [[ -z "$ws_ref" ]] && return 1

  echo "$tree_json" | jq -r --arg ws "$ws_ref" '
    [ .windows[].workspaces[] | select(.ref == $ws) |
      .panes[] |
      { pref: .ref, sref: .selected_surface_ref } as $p |
      { pref: $p.pref, sref: $p.sref, title: (.surfaces[] | select(.ref == $p.sref) | .title // "?") }
    ]
    | sort_by(.pref)
    | .[] | "\(.pref)\t\(.sref)\t\(.title)"
  '
}

# Detect the orchestrator pane: first look for a surface titled "*Orchestrator*"
# in the current workspace, then fall back to the caller surface.
detect_orch() {
  local tree_json orch_surface ws_ref
  tree_json="$(cmux tree --all --json 2>/dev/null)" || return 1
  ws_ref="$(echo "$tree_json" | jq -r '.caller.workspace_ref // empty' | tr -d '\n')"
  # Primary: find surface with "Orchestrator" in the title within caller's workspace
  if [[ -n "$ws_ref" ]]; then
    orch_surface="$(echo "$tree_json" | jq -r --arg ws "$ws_ref" '
      .windows[].workspaces[] | select(.ref == $ws) |
      .panes[].surfaces[] | select(.title? // "" | test("(?i)orchestrator")) | .ref
    ' | head -1)"
  fi
  # Fallback: caller surface
  if [[ -z "$orch_surface" ]]; then
    orch_surface="$(echo "$tree_json" | jq -r '.caller.surface_ref // empty')"
  fi
  echo "$orch_surface"
}

# ── init ─────────────────────────────────────────────────────────────
cmd_init() {
  local pane_map orch_surface
  pane_map="$(cmux_pane_map)" || die "failed to read cmux tree"
  orch_surface="$(detect_orch)" || die "cannot detect orchestrator"

  # Collect non-orchestrator panes, sorted by pane index.
  local workers=()
  while IFS=$'\t' read -r pref sref title; do
    [[ "$sref" == "$orch_surface" ]] && continue
    workers+=("$pref|$sref|$title")
  done <<< "$pane_map"

  local count=${#workers[@]}
  info "workspace has $count worker panes (orch=$orch_surface)"

  # Build the cockpit JSON
  local slots_json="{" orch_json
  orch_json="\"orchestrator\":{\"surface_ref\":\"$orch_surface\"}"

  local slot_names=("worker-1" "worker-2" "worker-3" "worker-4" "worker-5" "worker-6" "worker-7" "worker-8")
  local slot_entries=()
  local i
  for i in $(seq 0 7); do
    local slot="${slot_names[$i]}"
    if [[ $i -lt $count ]]; then
      local pref="${workers[$i]%%|*}"
      local sref="${workers[$i]#*|}"; sref="${sref%%|*}"
      slot_entries+=("\"$slot\":{\"pane_ref\":\"$pref\",\"surface_ref\":\"$sref\"}")
      # Rename the tab to the slot name
      cmux rename-tab --surface "$sref" "$slot" 2>/dev/null || true
    else
      slot_entries+=("\"$slot\":null")
    fi
  done

  # Build JSON
  local slots_body
  slots_body="$(printf ',%s' "${slot_entries[@]}")"
  slots_body="${slots_body:1}"  # remove leading comma

  cat > "$COCKPIT_FILE" <<JSON
{
  "version": 1,
  "workspace_ref": "$(cmux current-workspace 2>/dev/null || echo '?')",
  $orch_json,
  "slots": { $slots_body },
  "grid": "3x3",
  "layout": [
    ["worker-1", "worker-2", "worker-3"],
    ["worker-4", "ORCH",     "worker-5"],
    ["worker-6", "worker-7", "worker-8"]
  ]
}
JSON

  info "cockpit.json written ($count/8 slots mapped)"
  echo "cockpit: $count/8 slots populated"
}

# ── status ───────────────────────────────────────────────────────────
cmd_status() {
  if [[ ! -f "$COCKPIT_FILE" ]]; then
    echo "cockpit: not initialized (no .tasks/cockpit.json)"
    exit 1
  fi
  python3 -c "
import json, sys
with open('$COCKPIT_FILE') as f:
    c = json.load(f)
slots = c.get('slots', {})
populated = sum(1 for v in slots.values() if v is not None)
print(f'cockpit: {populated}/8 slots populated')
print()
# Print the grid
layout = c.get('layout', [])
for row in layout:
    line = ''
    for cell in row:
        if cell == 'ORCH':
            sref = c.get('orchestrator', {}).get('surface_ref', '?')
            line += f'[ORCH:{sref}]'.ljust(22)
        else:
            s = slots.get(cell)
            if s:
                line += f'[{cell}:{s[\"surface_ref\"]}]'.ljust(22)
            else:
                line += f'[{cell}:--]'.ljust(22)
    print(line)
"
}

# ── verify ───────────────────────────────────────────────────────────
cmd_verify() {
  if [[ ! -f "$COCKPIT_FILE" ]]; then
    echo "FAIL: cockpit.json not found"
    exit 1
  fi

  local pane_map orch_surface
  pane_map="$(cmux_pane_map)" || die "failed to read cmux tree"
  orch_surface="$(detect_orch)" || die "cannot detect orchestrator"

  local errors=0

  # Verify orchestrator surface matches
  local stored_orch
  stored_orch="$(python3 -c "import json; print(json.load(open('$COCKPIT_FILE'))['orchestrator']['surface_ref'])")"
  if [[ "$stored_orch" != "$orch_surface" ]]; then
    echo "FAIL: orchestrator surface mismatch: stored=$stored_orch actual=$orch_surface"
    errors=$((errors + 1))
  fi

  # Verify each slot's surface still exists in the workspace
  python3 -c "
import json, sys
with open('$COCKPIT_FILE') as f:
    c = json.load(f)
slots = c.get('slots', {})
live = set()
"'
import subprocess, json as j
tree = j.loads(subprocess.check_output(["cmux", "tree", "--all", "--json"], text=True))
for win in tree.get("windows", []):
    for ws in win.get("workspaces", []):
        for pane in ws.get("panes", []):
            live.add(pane.get("selected_surface_ref"))
'"
for name, slot in slots.items():
    if slot is None:
        print(f'WARN: {name} is empty (no pane assigned)')
        continue
    sref = slot['surface_ref']
    if sref not in live:
        print(f'FAIL: {name} surface {sref} no longer exists')
        sys.exit(1)
    else:
        print(f'OK: {name} → {sref}')
print('cockpit verify: OK')
"

  if [[ $errors -gt 0 ]]; then
    exit 1
  fi
}

# ── main ─────────────────────────────────────────────────────────────
case "${1:-}" in
  init)   cmd_init ;;
  status) cmd_status ;;
  verify) cmd_verify ;;
  *)
    echo "Usage: cmux-dev-grid <init|status|verify>"
    echo ""
    echo "  init     Build/verify 3×3 cockpit grid, rename tabs, save .tasks/cockpit.json"
    echo "  status   Print current slot→surface mapping"
    echo "  verify   Check cockpit.json against live cmux tree"
    exit 1
    ;;
esac
